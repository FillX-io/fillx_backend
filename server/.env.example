# Copy to server/.env and fill in. The real .env is git-ignored.

# Postgres connection string (Neon pooled connection recommended).
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Optional: override default HTTP port (default 8000)
# PORT=8000

AVATAR_S3_REGION=us-east-1
AVATAR_S3_INCOMING_BUCKET=fillx-incoming-avatars
AVATAR_S3_PUBLIC_BUCKET=fillx-public-avatars
AVATAR_PUBLIC_BASE_URL=https://fillx-public-avatars.s3.amazonaws.com

# Local MinIO only:
# AVATAR_S3_ENDPOINT=http://127.0.0.1:9000
# AVATAR_S3_FORCE_PATH_STYLE=true
