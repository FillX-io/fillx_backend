{
  "name": "@fillx/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "test:e2e": "tsx --test --test-concurrency=1 ../e2e/**/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fillx/shared": "0.1.0",
    "@orpc/contract": "^1.13.0",
    "@orpc/server": "^1.13.0",
    "bs58": "^6.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "pg": "^8.20.0",
    "tweetnacl": "^1.0.3",
    "viem": "^2.48.8",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@orpc/client": "^1.13.0",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
