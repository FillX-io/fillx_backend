{
  "name": "fillx-backend",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "yarn workspace @fillx/server dev",
    "build": "yarn workspace @fillx/shared build && yarn workspace @fillx/server build && yarn workspace @fillx/client build",
    "lint": "oxlint shared/ server/ client/",
    "fmt": "oxlint --fix shared/ server/ client/",
    "check": "yarn workspace @fillx/shared run check && yarn workspace @fillx/server run check && yarn workspace @fillx/client run check && yarn check:e2e",
    "check:e2e": "tsc --noEmit -p e2e/tsconfig.json",
    "e2e:minio:up": "docker compose -f docker-compose.e2e.yml up -d",
    "e2e:minio:down": "docker compose -f docker-compose.e2e.yml down",
    "e2e:minio:logs": "docker compose -f docker-compose.e2e.yml logs -f minio",
    "test:e2e": "yarn workspace @fillx/server test:e2e"
  },
  "devDependencies": {
    "oxlint": "^0.16.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
